# Plantilla de variables de entorno.
# Copia este archivo como .env y reemplaza los valores.
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

# Secreto para firmar/verificar el JWT (algoritmo HS256).
# Debe ser una cadena larga y aleatoria. NUNCA se hardcodea en el codigo.
JWT_SECRET=coloca-aqui-una-cadena-larga-y-aleatoria

# Puerto donde escucha el backend
PORT=3000
